# ── Local-first AI setup (no Garmin needed) ──────────────────────────
# Choose one provider:
# - gemma  -> local Ollama (recommended for localhost)
# - claude -> Anthropic API key required
AI_PROVIDER=gemma

# ── Local model (Ollama) ─────────────────────────────────────────────
# Required when AI_PROVIDER=gemma:
#   ollama serve
#   ollama pull gemma4:e2b
OLLAMA_URL=http://localhost:11434
GEMMA_MODEL=gemma4:e2b
# Vision model (defaults to GEMMA_MODEL if not set; fallback: gemma3:4b)
# GEMMA_VISION_MODEL=gemma4:e2b

# ── Claude API (optional, for toggle/comparison) ─────────────────────
# Required when AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Database (Neon Postgres) ─────────────────────────────────────────
# Get these from: Neon console → Project → Connection details
# DATABASE_URL      → pooled connection (for the backend runtime)
# DATABASE_URL_DIRECT → direct connection (for drizzle-kit migrations only)
DATABASE_URL=postgresql://drift_owner:<password>@<host>-pooler.sa-east-1.aws.neon.tech/drift?sslmode=require
DATABASE_URL_DIRECT=postgresql://drift_owner:<password>@<host>.sa-east-1.aws.neon.tech/drift?sslmode=require

# ── Storage ───────────────────────────────────────────────────────────
# UPLOAD_PATH=/data/uploads
