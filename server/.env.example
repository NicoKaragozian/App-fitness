# ── AI Provider Configuration ────────────────────────────────────────
# Default AI provider: 'gemma' (local, Ollama) or 'claude' (Anthropic API)
AI_PROVIDER=gemma

# ── Local model (Ollama) ─────────────────────────────────────────────
# Run: ollama serve && ollama pull gemma4:e2b
OLLAMA_URL=http://localhost:11434
GEMMA_MODEL=gemma4:e2b
# Vision model (defaults to GEMMA_MODEL if not set; fallback: gemma3:4b)
# GEMMA_VISION_MODEL=gemma4:e2b

# ── Claude API (optional, for toggle/comparison) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Database & Storage ───────────────────────────────────────────────
# DB_PATH=/data/drift.db
# UPLOAD_PATH=/data/uploads
